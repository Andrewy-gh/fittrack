#!/usr/bin/env sh

set -e

changed_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if echo "$changed_files" | grep -q '^client/'; then
  if command -v bun >/dev/null 2>&1; then
    bun run --cwd client lint
    bun run --cwd client knip
    bun run --cwd client test
  else
    pnpm -C client lint
    pnpm -C client knip
    pnpm -C client test
  fi
fi

if echo "$changed_files" | grep -q '^server/'; then
  server_changed_files="$(echo "$changed_files" | grep '^server/' || true)"
  server_non_docs_files="$(echo "$server_changed_files" | grep -Ev '^server/(README\.md|docs/|.*\.md$)' || true)"

  if [ -n "$server_non_docs_files" ]; then
    (cd server && make test-fast)
  else
    echo "server changes are docs-only; skipping fast server tests"
  fi
fi
