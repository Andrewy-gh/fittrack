# Required for Stack Auth in the browser
VITE_PROJECT_ID=your-stack-project-id
VITE_PUBLISHABLE_CLIENT_KEY=your-stack-publishable-client-key

# Optional when you want the client to hit a non-default API URL instead of the
# local Vite proxy or same-origin /api path.
# VITE_API_BASE_URL=http://localhost:8080
