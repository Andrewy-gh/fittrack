# Required for API startup
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/fittrack?sslmode=disable
PROJECT_ID=your-stack-project-id

# Common local defaults
PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development
RATE_LIMIT_RPM=100

# Optional local CORS overrides when you are not using the default Vite proxy.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional database pool tuning
DB_MAX_CONNS=15
DB_MIN_CONNS=2
DB_MAX_CONN_IDLE=30s
DB_MAX_CONN_LIFE=30m
DB_HEALTHCHECK=30s

# Optional metrics auth
# METRICS_USERNAME=metrics-user
# METRICS_PASSWORD=metrics-password

# Optional AI chat / Gemini smoke test
# GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODEL=googleai/gemini-2.5-flash

# Optional Playwright shortcut for creating Stack Auth sessions without UI login
# SECRET_SERVER_KEY=your-stack-secret-server-key
