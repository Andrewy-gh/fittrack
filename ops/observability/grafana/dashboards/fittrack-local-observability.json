          "expr": "sum(rate(ai_chat_client_outcomes_total{category=\"stream\",outcome=\"server_error\",cohort=\"$cohort\"}[15m])) / clamp_min(sum(rate(ai_chat_client_outcomes_total{category=\"stream\",outcome=~\"completed|server_error|transport_ended_pre_terminal|client_aborted\",cohort=\"$cohort\"}[15m])), 0.001)",
